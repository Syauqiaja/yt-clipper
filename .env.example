# YouTube Clipper Configuration
# Copy to .env and fill in your values

# 9Router AI API Configuration
NINEROUTER_API_KEY=sk-your-api-key-here
NINEROUTER_BASE_URL=https://api.9router.com/v1
NINEROUTER_MODEL=gpt-4o

# FFmpeg Path (auto-detected if empty)
FFMPEG_PATH=
FFPROBE_PATH=

# Output Quality (1-51, lower = better)
OUTPUT_QUALITY=23

# Default Clip Duration (seconds)
MAX_CLIP_DURATION=60
MIN_CLIP_DURATION=15

# Subtitle Style
SUBTITLE_FONT=Arial
SUBTITLE_FONT_SIZE=24
SUBTITLE_PRIMARY_COLOR=#FFFFFF
SUBTITLE_OUTLINE_COLOR=#000000

# Export
EXPORT_DIR=exports

# Whisper
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Google Drive
GOOGLE_OAUTH_CREDENTIALS_PATH=google_oauth_credentials.json
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_TOKEN_PATH=google_drive_token.json

# Webhooks
WEBHOOK_ENABLED=false
WEBHOOK_URL=

# Debug
DEBUG=false
LOG_LEVEL=INFO
